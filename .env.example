# Database
POSTGRES_DB=ai_textile_admin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_textile_admin

# Redis
REDIS_URL=redis://redis:6379/0

# Ollama (AI Model)
# Use http://host.docker.internal:11434 for Docker on Windows/Mac
# Use http://localhost:11434 if running without Docker
OLLAMA_BASE_URL=https://unshunted-clora-duodecimally.ngrok-free.dev
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_TEMPERATURE=0.2
# OLLAMA_TOP_P=
# OLLAMA_TOP_K=
# OLLAMA_REPEAT_PENALTY=

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false

# Storage
MEDIA_ROOT=/app/media
MAX_UPLOAD_MB=10

# Frontend
VITE_API_BASE_URL=http://localhost:8000
